# GrindBoard configuration
#
# Base URL of the alfa-leetcode-api instance the board reads from.
# https://github.com/alfaarghya/alfa-leetcode-api
#
# Leave unset to use the public default (https://alfa-leetcode-api.onrender.com).
# Note: VITE_ vars are inlined at BUILD time. To point at a self-hosted API you
# must either rebuild with this set, OR use the in-app "API base" field, which
# overrides this value at runtime and persists to localStorage.
#
# Self-host example:
# VITE_API_BASE=http://localhost:3000

VITE_API_BASE=https://alfa-leetcode-api.onrender.com
